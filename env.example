# PayVault API Configuration

# Server
PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://payvault:payvault@localhost:5432/payvault?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (CHANGE THESE IN PRODUCTION)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ENCRYPTION_KEY=your-64-char-hex-key-for-aes256-encryption-of-provider-secrets

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Webhook Relay
WEBHOOK_MAX_RETRIES=5
WEBHOOK_TIMEOUT_SEC=30

# Payment Links / Checkout
CHECKOUT_BASE_URL=https://pay.payvault.co
